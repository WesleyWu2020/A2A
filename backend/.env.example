# Database
DATABASE_URL=postgresql+asyncpg://nex:nex_password@localhost:5433/nex_db
DATABASE_URL_SYNC=postgresql://nex:nex_password@localhost:5433/nex_db

# Redis
REDIS_URL=redis://localhost:6379/0

# MiniMax LLM
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_API_BASE=https://api.minimaxi.chat/v1
MINIMAX_MODEL=MiniMax-Text-01

# Generic LLM provider (minimax/openai/zhipu)
LLM_PROVIDER=zhipu
LLM_API_KEY=your_llm_api_key_here
LLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL=glm-4-flash

# OpenAI (embeddings only)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Generic embedding provider (openai/zhipu)
EMBEDDING_PROVIDER=zhipu
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_API_BASE=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_MODEL=embedding-3

# Auth
SECRET_KEY=change-me-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=["http://localhost:5173"]
